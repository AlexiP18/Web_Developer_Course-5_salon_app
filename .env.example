# URL pública de la app (Railway Domain o dominio propio)
APP_URL=https://tu-app.up.railway.app
AUTH_COOKIE_SECRET=cambia-esto-por-una-clave-larga-y-segura

# DB (la app también soporta MYSQLHOST/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE de Railway)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=appsalon_mvc_php

# SMTP / Mail
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
MAIL_FROM=cuentas@appsalon.com
MAIL_FROM_NAME=AppSalon.com

# API de correo (si se define SENDGRID_API_KEY, se prioriza SendGrid sobre SMTP)
SENDGRID_API_KEY=
